		{"id":"7659e1165b73b38e","type":"text","text":"给儿童充分的自由","x":-177,"y":361,"width":145,"height":81,"color":"2"},
		{"id":"aaa2e1b2c46c6501","type":"text","text":"女子教育（保守）","x":190,"y":213,"width":250,"height":60},
		{"id":"3fce86c3dfb291c8","type":"text","text":"自然后果法：“通过孩子体验其过失的不良后果，来纠正他们的过失”","x":460,"y":213,"width":400,"height":88},
		{"id":"5a060f2639c01a84","type":"text","text":"事物的教育、人为的教育要以自然教育为基准","x":-549,"y":-14,"width":281,"height":88},
